  "instructions": [
    "Cook sushi rice according to package directions",
    "Mix rice vinegar, oil, and sugar, then fold into cooked rice",
    "Cut salmon into cubes and season with sesame oil, soy sauce, garlic powder, salt, and paprika",
    "Press sushi rice into a muffin tin lined with seaweed sheets",
    "Add seasoned salmon cubes to each rice-lined muffin cup",
    "Bake at 400\u00b0F for 12 minutes",
    "Mix mayonnaise and sriracha for spicy mayo",
    "Remove from oven and top each bite with spicy mayo and avocado slices",
    "Garnish with seaweed bits and chopped scallion",
    "Drizzle with honey and serve immediately"
  ],
  "tips": [
    "Use sushi-grade salmon for best results",
    "Muffin tin makes perfect bite-sized portions",
    "Can prep rice and salmon ahead of time",
    "Serve immediately after baking for best texture",
    "Customize with different toppings like cucumber or pickled ginger"
